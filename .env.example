# -----------------------------------------------------------------------------
# API keys — IMPORTANT
# Node's dotenv does NOT expand ${VAR}. Lines like OPENAI_API_KEY=${OPENROUTER_API_KEY}
# stay literal and OpenRouter returns "Missing Authentication header".
# Paste the full sk-or-v1-... string into OPENROUTER_API_KEY.
# Leave per-agent OpenRouter keys blank unless you explicitly want to override the shared key.
# -----------------------------------------------------------------------------
# Optional: DEBUG_LLM_AUTH=1 logs non-sensitive auth diagnostics only (no key fragments).

# === Shared OpenRouter key (fallback for all six agents) ===
OPENROUTER_API_KEY=sk-or-v1-paste-full-key-here

# GPT (via OpenRouter) — base URL must be https://openrouter.ai/api/v1 (no /chat/completions)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
GPT_MODEL=openai/gpt-4o-mini

# Claude (via OpenRouter)
CLAUDE_BASE_URL=https://openrouter.ai/api/v1
CLAUDE_API_KEY=
CLAUDE_MODEL=anthropic/claude-haiku-4.5

# DeepSeek (via OpenRouter)
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek/deepseek-v3.2

# Mistral (via OpenRouter)
MISTRAL_BASE_URL=https://openrouter.ai/api/v1
MISTRAL_API_KEY=
MISTRAL_MODEL=mistralai/ministral-3b-2512

# Grok (via OpenRouter)
GROK_BASE_URL=https://openrouter.ai/api/v1
XAI_API_KEY=
GROK_MODEL=x-ai/grok-4.3

# Gemini (via OpenRouter)
GEMINI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
GEMINI_MODEL=google/gemini-2.5-flash

X402_FACILITATOR_URL=https://facilitator.x402.org
BASE_SEPOLIA_RPC=https://sepolia.base.org
# USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# OWS CLI uses $HOME/.ows (it does not read OWS_VAULT_PATH). scripts/check-balances.sh
# sets HOME from OWS_VAULT_PATH when it ends in /.ows so it matches your vault.
OWS_VAULT_PATH=~/.ows
# Optional: comma-separated names exactly as in `ows wallet list` (default: NeetPoker agents + pot)
# OWS_WALLET_NAMES=grok,gpt,gemini,claude,mistral,deepseek,pot
# Optional: chain for `ows fund balance` (default: base mainnet). Base Sepolia example:
# OWS_FUND_BALANCE_CHAIN=eip155:84532
GROK_WALLET_ADDRESS=
GROK_PRIVATE_KEY=
GPT_WALLET_ADDRESS=
GPT_PRIVATE_KEY=
GEMINI_WALLET_ADDRESS=
GEMINI_PRIVATE_KEY=
CLAUDE_WALLET_ADDRESS=
CLAUDE_PRIVATE_KEY=
MISTRAL_WALLET_ADDRESS=
MISTRAL_PRIVATE_KEY=
DEEPSEEK_WALLET_ADDRESS=
DEEPSEEK_PRIVATE_KEY=
POT_WALLET_ADDRESS=
POT_PRIVATE_KEY=
STARTING_STACK=10
SMALL_BLIND=0.05
BIG_BLIND=0.1
HAND_DELAY_MS=2000
LLM_TIMEOUT_MS=12000
PAYMENT_RETRY_COUNT=1
PAYMENT_RETRY_TIMEOUT_MS=1500
MONTE_CARLO_SIMS=500
# true = skip on-chain USDC; use for local demo.
# false = real x402 payments: fund each agent wallet with Base Sepolia USDC (+ gas ETH).
MOCK_PAYMENTS=false
# Dev-only escape hatch: if x402 init fails and this is true, server falls back to full mock payments.
ALLOW_PAYMENT_BYPASS=false
PORT=8000
SERVER_PUBLIC_URL=http://localhost:8000
# Strong admin token (24+ random chars) required for mutating /game/* endpoints and /admin/feedback.
# GAME_ADMIN_TOKEN is preferred; FEEDBACK_ADMIN_TOKEN remains as backward-compatible fallback.
GAME_ADMIN_TOKEN=change-me
FEEDBACK_ADMIN_TOKEN=
# Comma-separated exact browser origins allowed for CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Manual /game/action API is disabled by default.
ENABLE_MANUAL_ACTION_API=0
# Optional custom path for private feedback storage (default: server/data/feedback.jsonl)
# FEEDBACK_STORE_PATH=/absolute/path/to/feedback.jsonl
VITE_WS_URL=ws://localhost:8000/ws
VITE_API_URL=http://localhost:8000
# Optional frontend token injection for dashboard controls (header: X-Admin-Token).
VITE_GAME_ADMIN_TOKEN=
# Optional repo link override used by the dashboard GitHub button.
VITE_REPO_URL=https://github.com/nikhildd32/NeetPoker
